{
  "name": "@hornjs/evt",
  "version": "0.0.0",
  "description": "Typed DOM-style event dispatching with cross-platform-consistent behavior.",
  "homepage": "https://github.com/hornjs/evt#readme",
  "license": "MIT",
  "author": "Maofeng <hornjs@qq.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hornjs/evt.git"
  },
  "files": [
    "dist",
    "package.json",
    "README.md",
    "README.zh-CN.md",
    "LICENSE"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "oxlint . && oxfmt --check .",
    "fmt": "oxlint --fix . && oxfmt .",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "release": "bumpp",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "7.0.0-dev.20260316.1",
    "bumpp": "^11.0.1",
    "oxfmt": "^0.37.0",
    "oxlint": "^1.52.0",
    "tsdown": "^0.21.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
